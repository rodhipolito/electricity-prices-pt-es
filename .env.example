# ENTSO-E Transparency Platform API key
# Request one at: https://transparency.entsoe.eu/ (Account Settings > Web API Security Token)
ENTSOE_API_KEY=your_entsoe_api_key_here

# Which database to write to: "local" (Docker Postgres) or "neon" (hosted Postgres)
# Defaults to "local" if unset.
DB_TARGET=local

# --- Local Postgres (used when DB_TARGET=local, e.g. via docker-compose.yml) ---
DB_USER=rodrigo
DB_PASSWORD=your_local_dev_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=energia_precos

# --- Neon (hosted Postgres, used when DB_TARGET=neon) ---
# Full connection string, e.g.: postgresql://user:password@ep-xxxx.neon.tech/dbname?sslmode=require
DATABASE_URL_NEON=postgresql://user:password@host/dbname?sslmode=require
